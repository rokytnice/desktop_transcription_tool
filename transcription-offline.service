[Unit]
Description=Desktop Transcription Tool (Offline)
Documentation=https://github.com/rokytnice/desktop_transcription_tool
After=pipewire.service pipewire-pulse.service

[Service]
Type=simple
Environment="WHISPER_MODEL=small"
Environment="WAYLAND_DISPLAY=wayland-0"
Environment="XDG_RUNTIME_DIR=/run/user/1000"
WorkingDirectory=/home/aroc/projects/desktop_transcription_tool/offline
ExecStart=/home/aroc/projects/desktop_transcription_tool/offline/.venv/bin/python /home/aroc/projects/desktop_transcription_tool/offline/transcription_offline.py -a
Restart=on-abort
RestartSec=30
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=default.target
